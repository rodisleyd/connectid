rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // CARDS COLLECTION
    match /cards/{cardId} {
      // READ: Public can read if active == true. Owner can always read.
      allow read: if resource.data.active == true || (request.auth != null && request.auth.uid == resource.data.userId);
      
      // CREATE: Authenticated users can create, but must set userId to their own auth.uid
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // DELETE: Only owner can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // UPDATE: 
      // 1. Owner can update everything
      // 2. Public (anyone) can update ONLY the 'analytics' field (for counters)
      allow update: if (request.auth != null && request.auth.uid == resource.data.userId)
                    || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['analytics']));
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
